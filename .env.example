DMHELPER_WRITER_MODEL=anthropic/claude-opus-4-8
DMHELPER_JUDGE_MODEL=anthropic/claude-sonnet-4-6
DMHELPER_WEB_MODEL=claude-sonnet-4-6
DMHELPER_JUDGE_ENABLED=true
DMHELPER_DATA_DIR=data
